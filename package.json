  "exports": {
    ".": "./src/index.tsx"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-ai",
    "tui",
    "sidebar",
    "session-switcher"
  ],
  "author": "wh0isroot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wh0isroot/opencode-session-tui.git"
  },
  "bugs": {
    "url": "https://github.com/wh0isroot/opencode-session-tui/issues"
  },
  "homepage": "https://github.com/wh0isroot/opencode-session-tui#readme",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.0",
    "@opencode-ai/sdk": ">=1.17.0",
    "solid-js": ">=1.8.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.13",
    "@opencode-ai/sdk": "^1.17.13",
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "solid-js": "^1.9.14",
    "typescript": "^6.0.3"
  }
